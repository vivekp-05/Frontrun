# Frontrun — environment template. Copy to .env.local and fill in.
# NEVER commit real keys. No paid API calls without a team decision (PRD §14).

# --- A · Backend (InsForge) ---
INSFORGE_PROJECT_URL=
INSFORGE_API_KEY=
INSFORGE_LEADS_TABLE=leads
PORT=4000
# SEED_DEMO=1 boots A's server with the demo fixtures loaded
SEED_DEMO=

# --- A · Analytics (Hydra) ---
HYDRA_DB_URL=

# --- B · Signal + enrichment ---
# SEC EDGAR needs a descriptive User-Agent (quote it — it contains spaces), no key.
EDGAR_USER_AGENT="Your Name your.email@example.com"
# You.com: YDC_API_KEY unlocks the paid Research MCP tool; YOU_MCP_URL is the free search.
YDC_API_KEY=
YOUCOM_API_KEY=
YOU_MCP_URL=https://api.you.com/mcp?profile=free
FIRECRAWL_API_KEY=
NIMBLE_API_KEY=
HUNTER_API_KEY=
REOON_API_KEY=
# RocketRide (pipeline orchestration prize). rr_ key = orchestration auth only.
ROCKETRIDE_API_KEY=
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_AUTH=
# BYOK inference: the drafting agent's LLM node needs ONE provider key (sk-...).
# Without it the pipe connects/validates/deploys but produces no draft text.
ROCKETRIDE_OPENAI_KEY=

# --- D · Outreach + reply loop ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Band (multi-agent triage coordination). Missing agent keys => local coordinator.
# The HUMAN key registers agents; runtime coordination uses the 3 AGENT keys below.
BAND_API_KEY=                          # human/user key — only for band.provision.mjs
BAND_API_URL=https://app.band.ai/api/v1
BAND_OWNER_HANDLE=                     # e.g. in.vivekpatel (owner in owner/agent-slug)
BAND_TASKS=0                           # 1 to attempt the Beta task board (404s on Free)
# Registered triage agents — fill by running: node workstream-d-outreach/band.provision.mjs
BAND_AGENT_SUMMARIZER_ID=
BAND_AGENT_SUMMARIZER_HANDLE=
BAND_AGENT_SUMMARIZER_KEY=
BAND_AGENT_CLASSIFIER_ID=
BAND_AGENT_CLASSIFIER_HANDLE=
BAND_AGENT_CLASSIFIER_KEY=
BAND_AGENT_DRAFTER_ID=
BAND_AGENT_DRAFTER_HANDLE=
BAND_AGENT_DRAFTER_KEY=
RESEND_WEBHOOK_SECRET=                  # Svix signing secret (whsec_...) for the route
CALCOM_API_KEY=
CALCOM_WEBHOOK_SECRET=                  # HMAC secret for the Cal.com webhook route
CALCOM_LINK=
FROM_NAME=Dana
FROM_COMPANY=Frontrun Talent
# TRIAGE_MODEL overrides the InsForge gateway model (default anthropic/claude-sonnet-4)
TRIAGE_MODEL=

# --- Demo-rehearsal switches ---
# MOCK_SEND=1 / MOCK_LLM=1 force the deterministic (no-network) paths.
# ALLOW_REAL_SEND=1 lets runOutreach email non-demo leads (PRD §6 — leave unset!).
MOCK_SEND=
MOCK_LLM=
ALLOW_REAL_SEND=

# --- Demo inboxes (the 3 controlled prospects) ---
DEMO_INBOX_1=
DEMO_INBOX_2=
DEMO_INBOX_3=
